{
  "manifest_version": 3,
  "name": "한 줄 EPUB 리더",
  "version": "1.3",
  "permissions": ["storage", "activeTab", "tabs"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["jszip.min.js", "content.js"]
    }
  ],
  "action": {}
}
